---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';

interface Project {
  id: string;
  name: string;
  href?: string;
  image: string;
  imageAlt: string;
  description: string;
  stack: string[];
  awards?: string[];
}

const projects: Project[] = [
  {
    id: 'fourchal',
    name: 'Fourchal',
    href: 'http://www.fourchal.com',
    image: '/assets/images/fourchal.jpeg',
    imageAlt: 'Fourchal screenshot',
    description:
      'Started at the Goodnik Helping Hacks Hackathon. A platform that helps nonprofits source volunteers by gamifying the process — organizations create challenges with points, prizes, and badges, and volunteers complete those challenges for swag.',
    stack: ['Ruby on Rails', 'PostgreSQL', 'Haml', 'RSpec', 'Cucumber'],
  },
  {
    id: 'mood-music',
    name: 'Mood Music',
    href: 'http://mood-music.herokuapp.com',
    image: '/assets/images/mqdefault.jpg',
    imageAlt: 'Mood Music screenshot',
    description:
      "An app that takes a picture of your face, recognizes your mood, and plays music to match. Won Best Mashery App and Best Video Hack at Hack N' Jill.",
    stack: ['Ruby on Rails', 'jQuery', 'Face.com API'],
    awards: ["Best Mashery App — Hack N' Jill", "Best Video Hack — Hack N' Jill"],
  },
  {
    id: 'nowtutor',
    name: 'NowTutor.Me',
    image: '/assets/images/NowTutormeLogo.png',
    imageAlt: 'NowTutor.Me logo',
    description:
      'A website where tutors and students can connect for free. Won Best Web Application at the Spring 2012 Princeton Hackathon.',
    stack: ['PHP', 'jQuery', 'MySQL'],
    awards: ['Best Web Application — Princeton Hackathon 2012'],
  },
  {
    id: 'puttpartee',
    name: 'PuttPartee',
    image: '/assets/images/MainScreen2.png',
    imageAlt: 'PuttPartee screenshot',
    description:
      'A cross-platform golf puzzler with physics! Aimed at Android platforms, built with the LibGDX framework.',
    stack: ['Java', 'LibGDX'],
  },
  {
    id: 'easymood',
    name: 'Easy Mood',
    image: '/assets/images/EasyMood.png',
    imageAlt: 'Easy Mood screenshot',
    description:
      'My first web app. Enter your zip code and it returns a LOLCat picture based on your local weather, plus local news. Won Best Mashery Application at Penn Apps Spring 2012.',
    stack: ['PHP', 'jQuery', 'MySQL'],
    awards: ['Best Mashery Application — Penn Apps Spring 2012'],
  },
];
---

<BaseLayout
  title="Projects — Koushik Dasika"
  description="A portfolio of projects spanning web apps, mobile games, and hackathon wins."
>
  <Header />
  <main class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Projects</h1>
    <p class="text-muted-foreground mb-10">
      A selection of things I've built — from hackathon sprints to side projects.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <article
          id={project.id}
          class="group rounded-xl border border-border bg-card overflow-hidden hover:border-primary/50 transition-all hover:shadow-md hover:-translate-y-0.5 flex flex-col"
        >
          <!-- Image -->
          <div class="aspect-video bg-muted overflow-hidden">
            <img
              src={project.image}
              alt={project.imageAlt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>

          <!-- Content -->
          <div class="p-5 flex flex-col flex-1">
            <div class="mb-3">
              {project.href ? (
                <a
                  href={project.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-lg font-semibold hover:text-primary transition-colors"
                >
                  {project.name}
                  <span class="ml-1 text-muted-foreground text-sm">↗</span>
                </a>
              ) : (
                <h2 class="text-lg font-semibold">{project.name}</h2>
              )}
            </div>

            <p class="text-sm text-muted-foreground leading-relaxed mb-4 flex-1">
              {project.description}
            </p>

            {project.awards && project.awards.length > 0 && (
              <div class="mb-4 space-y-1">
                {project.awards.map((award) => (
                  <div class="flex items-center gap-1.5 text-xs text-amber-600 dark:text-amber-400">
                    <span aria-hidden="true">🏆</span>
                    {award}
                  </div>
                ))}
              </div>
            )}

            <!-- Tech stack -->
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {project.stack.map((tech) => (
                <Badge variant="secondary" class="text-xs">{tech}</Badge>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
