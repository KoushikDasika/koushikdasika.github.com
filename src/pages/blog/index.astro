---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Badge } from '@/components/ui/badge';
import { Separator } from '@/components/ui/separator';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog — Koushik Dasika" description="Writing on algorithms, math, and building things.">
  <Header />
  <main class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8">
      <!-- Post list -->
      <div>
        <h1 class="text-3xl font-bold tracking-tight mb-8">Blog</h1>
        <div class="space-y-6">
          {posts.map((post, i) => {
            const formatted = new Intl.DateTimeFormat('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            }).format(post.data.date);
            return (
              <article>
                {i > 0 && <Separator className="mb-6" />}
                <div class="flex flex-wrap gap-2 mb-2">
                  {post.data.categories?.map((cat) => (
                    <Badge variant="secondary" class="text-xs">{cat}</Badge>
                  ))}
                </div>
                <h2 class="text-xl font-semibold mb-1">
                  <a
                    href={`/blog/${post.slug}`}
                    class="hover:text-primary transition-colors"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-sm text-muted-foreground mb-3">
                  <time datetime={post.data.date.toISOString()}>{formatted}</time>
                </p>
                {post.data.description && (
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    {post.data.description}
                  </p>
                )}
                <a
                  href={`/blog/${post.slug}`}
                  class="inline-block mt-3 text-sm text-primary hover:underline underline-offset-4"
                >
                  Read more →
                </a>
              </article>
            );
          })}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="rounded-xl border border-border p-5 bg-card">
          <h2 class="font-semibold text-sm uppercase tracking-wider text-muted-foreground mb-4">
            Recent Posts
          </h2>
          <ul class="space-y-3">
            {posts.map((post) => {
              const formatted = new Intl.DateTimeFormat('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              }).format(post.data.date);
              return (
                <li>
                  <a
                    href={`/blog/${post.slug}`}
                    class="text-sm hover:text-primary transition-colors"
                  >
                    {post.data.title}
                  </a>
                  <p class="text-xs text-muted-foreground mt-0.5">{formatted}</p>
                </li>
              );
            })}
          </ul>
        </div>

        <div class="rounded-xl border border-border p-5 bg-card">
          <h2 class="font-semibold text-sm uppercase tracking-wider text-muted-foreground mb-4">
            Categories
          </h2>
          <div class="flex flex-wrap gap-2">
            {[...new Set(posts.flatMap((p) => p.data.categories ?? []))].map((cat) => (
              <Badge variant="outline" class="text-xs">{cat}</Badge>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
