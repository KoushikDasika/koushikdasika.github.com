---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Separator } from '@/components/ui/separator';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const techStack = {
  'Languages': ['Elixir', 'JavaScript', 'TypeScript', 'Ruby', 'Python'],
  'Other Languages': ['Java', 'C', 'Golang'],
  'Frameworks': ['Phoenix', 'React', 'Node.js', 'Ruby on Rails'],
  'Infrastructure': ['AWS', 'Kubernetes', 'Docker', 'Terraform', 'EKS'],
  'Data': ['PostgreSQL', 'MongoDB', 'DynamoDB', 'Kafka', 'Elasticsearch', 'OpenSearch', 'Redis'],
  'Practices': ['Event Sourcing', 'CI/CD', 'Agile', 'Infrastructure as Code'],
};
const interests = ['Baking', 'Running', 'AI/ML'];
---

<BaseLayout
  title="Koushik Dasika — Hacker, Builder, Engineering Leader"
  description="Engineering leader with 13+ years building and scaling teams, platforms, and products. Currently leading engineering at Automatiq."
>
  <Header />
  <main class="max-w-5xl mx-auto px-4 py-12">

    <!-- Hero -->
    <section class="mb-16">
      <div class="relative rounded-2xl border border-border bg-card overflow-hidden p-8 sm:p-12">
        <!-- Gradient accent blob -->
        <div
          class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-primary/10 blur-3xl pointer-events-none"
          aria-hidden="true"
        />
        <div class="relative">
          <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 text-primary px-3 py-1 text-xs font-medium mb-4">
            👋 Hey there
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">
            Koushik Dasika
          </h1>
          <p class="text-xl text-muted-foreground mb-6">
            Hacker &middot; Builder &middot; Engineering Leader
          </p>
          <p class="text-foreground/80 leading-relaxed max-w-2xl mb-8">
            Engineering leader with 13+ years of experience building software, scaling infrastructure,
            and growing teams. Currently leading a team of 13 engineers at Automatiq, where we're
            building AI-powered features and shipping across marketplace, payments, and white-label
            ticketing products.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button asChild>
              <a href="/blog">Read the Blog</a>
            </Button>
            <Button variant="ghost" asChild>
              <a href="https://github.com/KoushikDasika" target="_blank" rel="noopener noreferrer">
                GitHub ↗
              </a>
            </Button>
          </div>
        </div>
      </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-10">
      <!-- Left column -->
      <div class="space-y-12">

        <!-- About -->
        <section>
          <h2 class="text-2xl font-bold tracking-tight mb-4">About</h2>
          <div class="space-y-4 text-foreground/80 leading-relaxed">
            <p>
              I've spent the last 13+ years building software and leading engineering teams across
              startups in NYC. I started as a hands-on full-stack engineer and grew through Staff
              and Principal roles before moving into engineering leadership — but I've never stopped
              writing code.
            </p>
            <p>
              I'm at my best when I'm building high-performing teams, designing systems that scale,
              and solving hard infrastructure problems. I've migrated entire platforms to Kubernetes,
              built real-time inventory systems with Kafka and event sourcing, and helped teams ship
              faster by investing in tooling, CI/CD, and engineering culture.
            </p>
            <p>
              I also love teaching. Earlier in my career, I tutored for years, led CS recitations at
              Rutgers, and even wrote my own 150-page calculus textbook. That instinct to share
              knowledge still shows up in how I lead — through mentorship, skillshares, and making
              sure everyone on the team is growing.
            </p>
          </div>
        </section>

        <Separator />

        <!-- What I'm Focused On -->
        <section>
          <h2 class="text-2xl font-bold tracking-tight mb-4">What I'm Focused On</h2>
          <p class="text-foreground/80 leading-relaxed">
            At Automatiq, I lead engineering across three product areas — our B2B marketplace,
            Instant Sites (white-label ticketing storefronts), and Payments infrastructure. I'm
            currently driving our AI-powered feature roadmap, including semantic search, LLM-based
            catalog enrichment, and MCP server integrations.
          </p>
          <p class="mt-4 text-foreground/80 leading-relaxed">
            Beyond shipping features, I focus on the fundamentals that make teams effective:
            infrastructure optimization (we cut AWS spend by 60% while scaling to 40%+ more traffic),
            hiring and onboarding great engineers, and building the processes that help everyone
            do their best work.
          </p>
        </section>

        <Separator />

        <!-- Tech -->
        <section>
          <h2 class="text-2xl font-bold tracking-tight mb-4">Tech Stack</h2>
          <div class="space-y-4">
            {Object.entries(techStack).map(([category, items]) => (
              <div>
                <p class="text-sm text-muted-foreground mb-2 uppercase tracking-wider font-medium">{category}</p>
                <div class="flex flex-wrap gap-2">
                  {items.map((item) => (
                    <Badge variant={category === 'Languages' || category === 'Frameworks' ? 'default' : 'outline'}>{item}</Badge>

                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- Right sidebar -->
      <aside class="space-y-6">

        <!-- Recent Posts -->
        <div class="rounded-xl border border-border p-5 bg-card">
          <h2 class="font-semibold text-sm uppercase tracking-wider text-muted-foreground mb-4">
            Recent Posts
          </h2>
          <ul class="space-y-4">
            {recentPosts.map((post) => {
              const formatted = new Intl.DateTimeFormat('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              }).format(post.data.date);
              return (
                <li>
                  <a
                    href={`/blog/${post.slug}`}
                    class="text-sm font-medium hover:text-primary transition-colors"
                  >
                    {post.data.title}
                  </a>
                  <p class="text-xs text-muted-foreground mt-0.5">{formatted}</p>
                </li>
              );
            })}
          </ul>
          <a
            href="/blog"
            class="block mt-4 text-xs text-primary hover:underline underline-offset-4"
          >
            All posts →
          </a>
        </div>

        <!-- Interests -->
        <div class="rounded-xl border border-border p-5 bg-card">
          <h2 class="font-semibold text-sm uppercase tracking-wider text-muted-foreground mb-4">
            Interests
          </h2>
          <ul class="space-y-1.5">
            {interests.map((item) => (
              <li class="text-sm text-foreground/80 flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-primary inline-block" aria-hidden="true" />
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Connect -->
        <div class="rounded-xl border border-border p-5 bg-card">
          <h2 class="font-semibold text-sm uppercase tracking-wider text-muted-foreground mb-4">
            Connect
          </h2>
          <div class="space-y-2">
            <a
              href="https://github.com/KoushikDasika"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm hover:text-primary transition-colors"
            >
              <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
              </svg>
              @KoushikDasika
            </a>
            <a
              href="https://www.linkedin.com/in/koushikdasika/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm hover:text-primary transition-colors"
            >
              <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
